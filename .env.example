# API Gateway origin (no trailing slash). All auth/chat/users/media calls go
# through here with a real JWT — no internal token is ever exposed to the browser.
VITE_GATEWAY_URL=http://localhost:4000

# Realtime WebSocket origin (no trailing slash) — realtime-service, connected
# to directly (Socket.IO), e.g. http://localhost:3001
VITE_REALTIME_URL=http://localhost:3001

# Google OAuth2 client id (same value as auth-service's GOOGLE_CLIENT_ID).
VITE_GOOGLE_CLIENT_ID=
